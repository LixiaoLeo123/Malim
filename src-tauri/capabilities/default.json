{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "media-toolkit:allow-play",
    "dialog:allow-open",
    "dialog:allow-save",
    
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$TEMP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    }
  ]
}
